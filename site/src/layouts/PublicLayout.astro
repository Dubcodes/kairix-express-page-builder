---
import { assetPath, content, sitePath } from "../lib/content.js";

const { title, description = content.settings.introText } = Astro.props;
const s = content.settings;
const theme = s.theme || "clean-light";
---
<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content={description}>
    <title>{title ? `${title} - ${s.brandName}` : s.brandName}</title>
    <style is:global>
      :root {
        --bg: #f7f9fb;
        --surface: #ffffff;
        --surface-alt: #fbfdff;
        --text: #17202a;
        --muted: #667085;
        --line: #d8dee7;
        --line-strong: #b9c3d1;
        --accent: #0b6bcb;
        --accent-2: #0f766e;
        --warn: #b54708;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }
      [data-theme="dark-tech"] {
        --bg: #101820;
        --surface: #172331;
        --surface-alt: #1d2b3a;
        --text: #eef4f8;
        --muted: #aab7c4;
        --line: #2c3e4f;
        --line-strong: #476174;
        --accent: #54c6eb;
        --accent-2: #7dd3a9;
      }
      [data-theme="blue-commerce"] {
        --bg: #edf6ff;
        --surface: #ffffff;
        --surface-alt: #f8fbff;
        --text: #102033;
        --muted: #52677c;
        --line: #bfd3e8;
        --line-strong: #9eb9d4;
        --accent: #075bbb;
        --accent-2: #0f766e;
      }
      [data-theme="warm-simple"] {
        --bg: #faf7f2;
        --surface: #ffffff;
        --surface-alt: #fffdf9;
        --text: #231f20;
        --muted: #6f6258;
        --line: #e1d8cf;
        --line-strong: #cdbdac;
        --accent: #b44818;
        --accent-2: #527853;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
      }
      a { color: var(--accent); }
      img { max-width: 100%; height: auto; display: block; }
      label {
        display: grid;
        gap: 6px;
        font-weight: 700;
      }
      input,
      select,
      textarea {
        width: 100%;
        min-height: 42px;
        border: 1px solid var(--line-strong);
        border-radius: 6px;
        background: var(--surface);
        color: var(--text);
        padding: 9px 11px;
        font: inherit;
      }
      textarea {
        min-height: 120px;
        line-height: 1.5;
        resize: vertical;
      }
      .site-header {
        background: var(--surface);
        border-bottom: 1px solid var(--line);
      }
      .inner {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
      }
      .nav {
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--text);
        text-decoration: none;
        font-weight: 750;
      }
      .brand img {
        width: 42px;
        height: 42px;
        object-fit: contain;
      }
      .nav-links {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        align-items: center;
      }
      .nav-links a {
        text-decoration: none;
        color: var(--text);
      }
      .hero {
        padding: 42px 0 26px;
      }
      .hero h1 {
        margin: 0 0 10px;
        font-size: clamp(34px, 7vw, 58px);
        line-height: 1;
        letter-spacing: 0;
      }
      .hero p {
        max-width: 760px;
        margin: 0;
        color: var(--muted);
        font-size: 18px;
      }
      .section {
        padding: 20px 0;
      }
      .section h2 {
        margin: 0 0 14px;
        font-size: 24px;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 14px;
      }
      .card {
        border: 1px solid var(--line-strong);
        border-radius: 8px;
        background: var(--surface);
        padding: 16px;
        box-shadow: 0 1px 0 rgba(16, 24, 40, 0.04);
      }
      .product-card-link {
        display: block;
        color: var(--text);
        text-decoration: none;
      }
      .product-card-link:hover {
        border-color: var(--accent);
      }
      .card h3 {
        margin: 0 0 6px;
      }
      .card p {
        line-height: 1.55;
      }
      .muted { color: var(--muted); }
      .eyebrow {
        margin: 0 0 4px;
        color: var(--accent);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0;
        text-transform: uppercase;
      }
      .section-heading-public {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 14px;
      }
      .section-heading-public h2,
      .section-heading-public p {
        margin: 0;
      }
      .section-heading-public p {
        margin-top: 4px;
      }
      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
      }
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 40px;
        border-radius: 6px;
        padding: 0 13px;
        color: #fff;
        background: var(--accent);
        text-decoration: none;
        border: 0;
        cursor: pointer;
        font: inherit;
      }
      .button.secondary {
        color: var(--accent);
        background: var(--surface);
        border: 1px solid var(--line-strong);
      }
      .button.secondary:hover,
      .button.secondary.active-filter {
        color: #fff;
        background: var(--accent);
        border-color: var(--accent);
      }
      .pill {
        display: inline-flex;
        align-items: center;
        min-height: 24px;
        border-radius: 999px;
        background: var(--surface-alt);
        border: 1px solid var(--line);
        color: var(--text);
        padding: 0 9px;
        font-size: 12px;
      }
      .site-footer {
        margin-top: 36px;
        padding: 28px 0;
        border-top: 1px solid var(--line);
        color: var(--muted);
      }
      .placeholder-media {
        min-height: 180px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        border: 1px solid var(--line);
        background: var(--surface-alt);
        color: var(--muted);
      }
      .filter-panel {
        display: grid;
        grid-template-columns: minmax(240px, 1fr) auto;
        gap: 12px;
        align-items: end;
        border: 1px solid var(--line-strong);
        border-radius: 8px;
        background: var(--surface);
        padding: 14px;
        margin-bottom: 14px;
      }
      .type-filter {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
      }
      .download-list {
        display: grid;
        gap: 12px;
      }
      .download-card,
      .version-card {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 16px;
        align-items: center;
      }
      .bundle-card {
        background: var(--surface-alt);
      }
      .download-card-main {
        min-width: 0;
      }
      .download-card-main h3,
      .version-card h3 {
        font-size: 20px;
      }
      .download-card-main p,
      .version-card p {
        margin: 6px 0 0;
      }
      .download-actions {
        justify-content: flex-end;
      }
      .release-notes > :first-child {
        margin-top: 8px;
      }
      .release-notes > :last-child {
        margin-bottom: 0;
      }
      .current-version {
        border-color: var(--accent);
      }
      .warning-text {
        color: var(--warn);
        font-weight: 700;
      }
      .checksum {
        overflow-wrap: anywhere;
      }
      .qr-popover {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 10;
        background: rgba(0, 0, 0, 0.48);
        place-items: center;
        padding: 20px;
      }
      .qr-popover.open { display: grid; }
      .qr-box {
        width: min(320px, 100%);
        border-radius: 8px;
        background: #fff;
        color: #17202a;
        padding: 18px;
      }
      @media (max-width: 720px) {
        .nav {
          align-items: flex-start;
          flex-direction: column;
          padding: 14px 0;
        }
        .filter-panel,
        .download-card,
        .version-card {
          grid-template-columns: 1fr;
        }
        .type-filter,
        .download-actions {
          justify-content: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="inner nav">
        <a class="brand" href={sitePath("/")}>
          {s.logo && <img src={assetPath(s.logo)} alt="">}
          <span>{s.brandName}</span>
        </a>
        <nav class="nav-links" aria-label="Main navigation">
          <a href={sitePath("/")}>Home</a>
          <a href={sitePath("/downloads/")}>Downloads</a>
          <a href={sitePath("/support/")}>Support</a>
          {s.marketplaceUrl && <a href={s.marketplaceUrl}>Store</a>}
        </nav>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="inner">
        <p>{s.footerText || `${s.brandName} product support`}</p>
      </div>
    </footer>
  </body>
</html>
