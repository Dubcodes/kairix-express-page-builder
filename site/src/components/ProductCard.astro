---
import { productImage, sitePath, stockLabel } from "../lib/content.js";
const { product } = Astro.props;
const image = productImage(product);
const stock = stockLabel(product);
const stockClass = stock.includes("Out") ? "pill-danger" : stock.includes("Almost") ? "pill-almost-out" : stock.includes("Low") ? "pill-low-stock" : "pill-success";
---
<a class="card product-card-link" href={sitePath(`/products/${product.slug}/`)}>
  {image ? <img src={image} alt={product.name}> : <div class="placeholder-media" style="margin-bottom: 12px;">Product image</div>}
  <h3>{product.name}</h3>
  {product.sku && <p class="muted">SKU: {product.sku}</p>}
  {stock && <p><span class={`pill ${stockClass}`} title="Availability shown by the seller">{stock}</span></p>}
  <p>{product.short_description}</p>
</a>
