---
import PublicLayout from "../layouts/PublicLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import { assetPath, content, sitePath, trackScript } from "../lib/content.js";

const s = content.settings;
const featured = content.products.filter((product) => product.featured).slice(0, 6);
const recent = content.products.slice(0, 6);
const homeProducts = featured.length ? featured : recent;
const heroTitle = s.homeHeroTitle || s.brandName;
const showCategories = s.homeShowCategories !== false;
const showProducts = s.homeShowFeaturedProducts !== false;
const showSupportCta = s.homeShowSupportCta !== false;
const showDownloadsSummary = s.homeShowDownloadsSummary === true;
const blockImages = Array.isArray(s.homeTextBlockImages)
  ? s.homeTextBlockImages
  : (s.homeTextBlockImage ? [s.homeTextBlockImage] : []);
const showTextBlock = s.homeTextBlockEnabled && (s.homeTextBlockHeading || s.homeTextBlockText || blockImages.length);
---
<PublicLayout title="Home">
  <main>
    <section class:list={["hero", "inner", s.homeHeroImage && "hero-with-media"]}>
      <div>
        <h1>{heroTitle}</h1>
        <p>{s.introText}</p>
      </div>
      {s.homeHeroImage && <img class="hero-image" src={assetPath(s.homeHeroImage)} alt="" loading="eager">}
    </section>
    {showTextBlock && (
      <section class="section inner">
        <article class:list={["card", "info-block", blockImages.length && "info-block-with-media"]}>
          <div>
            {s.homeTextBlockHeading && <h2>{s.homeTextBlockHeading}</h2>}
            {s.homeTextBlockText && <div class="rich-text" set:html={s.homeTextBlockText} />}
          </div>
          {blockImages.length > 0 && (
            <div class="info-block-images">
              {blockImages.map((image) => <img class="info-block-image" src={assetPath(image)} alt="" loading="lazy">)}
            </div>
          )}
        </article>
      </section>
    )}
    {showCategories && (
      <section class="section inner">
        <h2>Product categories</h2>
        <div class="grid">
          {content.categories.map((category) => (
            <article class="card">
              <h3>{category.name}</h3>
              <p>{category.description}</p>
              <a class="button secondary" href={sitePath(`/categories/${category.slug}/`)}>View products</a>
            </article>
          ))}
        </div>
      </section>
    )}
    {showProducts && (
      <section class="section inner">
        <h2>{featured.length ? "Featured products" : "Recent products"}</h2>
        <div class="grid product-grid">
          {homeProducts.map((product) => <ProductCard product={product} />)}
        </div>
      </section>
    )}
    {showSupportCta && (
      <section class="section inner">
        <article class="card support-cta-card">
          <div>
            <h2>{s.homeSupportHeading || "Support"}</h2>
            <p class="muted">{s.homeSupportText || "Need product help, setup details, manuals or store links?"}</p>
          </div>
          <a class="button" href={sitePath("/support/")}>{s.homeSupportButtonLabel || "Contact support"}</a>
        </article>
      </section>
    )}
    {showDownloadsSummary && (
      <section class="section inner">
        <article class="card support-cta-card">
          <div>
            <h2>Downloads</h2>
            <p class="muted">Find manuals, firmware, apps and setup files for supported products.</p>
          </div>
          <a class="button secondary" href={sitePath("/downloads/")}>Open downloads</a>
        </article>
      </section>
    )}
  </main>
  <script is:inline set:html={trackScript("page_view")} />
</PublicLayout>
