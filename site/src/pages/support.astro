---
import PublicLayout from "../layouts/PublicLayout.astro";
import { content, trackScript } from "../lib/content.js";
const s = content.settings;
const contactMethods = s.contactMethods?.length ? s.contactMethods : [
  s.supportEmail && { label: "Email", type: "email", value: s.supportEmail },
  s.supportLink && { label: "Support link", type: "link", value: s.supportLink },
  s.marketplaceUrl && { label: "Marketplace store", type: "marketplace", value: s.marketplaceUrl }
].filter(Boolean);
const fallbackSupportText = "Use the contact details below for product support, manuals, firmware, app downloads, and marketplace order questions.";
const hrefFor = (method) => method.type === "email"
  ? `mailto:${method.value}`
  : method.type === "phone"
    ? `tel:${method.value}`
    : method.value;
---
<PublicLayout title="Support">
  <main>
    <section class="hero inner">
      <h1>Support</h1>
      <p>{s.homeSupportText || fallbackSupportText}</p>
    </section>
    <section class="section inner">
      <div class="grid">
        {contactMethods.map((method) => (
          <article class="card">
            <h2>{method.label}</h2>
            <a href={hrefFor(method)}>{method.value}</a>
          </article>
        ))}
        {!contactMethods.length && (
          <article class="card">
            <h2>Product support</h2>
            <p class="muted">{fallbackSupportText}</p>
          </article>
        )}
      </div>
    </section>
    {content.runtimeApiEnabled && s.contactFormEnabled && (
      <section class="section inner">
        <h2>Contact support</h2>
        <p class="muted">For order or payment issues, use your marketplace order page. For setup, downloads, manuals or firmware help, send a message here.</p>
        <form id="contactForm" class="card" style="display: grid; gap: 12px;">
          <label style="position:absolute; left:-10000px; width:1px; height:1px; overflow:hidden;" aria-hidden="true" tabindex="-1">Company website<input name="companyWebsite" autocomplete="off" tabindex="-1"></label>
          <label>Name<input name="name" required></label>
          <label>Email<input name="email" type="email" required></label>
          <label>Product
            <select name="productId">
              <option value="">Not sure / general question</option>
              {content.products.map((product) => <option value={product.id}>{product.name}</option>)}
            </select>
          </label>
          <label>Message<textarea name="message" required></textarea></label>
          <button class="button" type="submit">Send message</button>
          <p id="contactStatus" class="muted"></p>
        </form>
      </section>
    )}
  </main>
  <script is:inline set:html={trackScript("page_view")} />
  {content.runtimeApiEnabled && <script is:inline>
    var contactForm = document.querySelector("#contactForm");
    if (contactForm) {
      contactForm.addEventListener("submit", function(event) {
        event.preventDefault();
        var status = document.querySelector("#contactStatus");
        var data = Object.fromEntries(new FormData(contactForm));
        data.productId = data.productId ? Number(data.productId) : null;
        fetch("/api/contact-submissions", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data)
        }).then(function(response) {
          if (!response.ok) throw new Error("Contact form unavailable");
          status.textContent = "Message sent.";
          contactForm.reset();
          if (window.KAIRIX_TRACK) window.KAIRIX_TRACK("contact_form_submission", {});
        }).catch(function() {
          status.textContent = "The form is unavailable here. Please use the support email or link above.";
        });
      });
    }
  </script>}
</PublicLayout>
