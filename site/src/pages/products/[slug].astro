---
import PublicLayout from "../../layouts/PublicLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import DownloadCard from "../../components/DownloadCard.astro";
import { assetPath, content, sitePath, stockLabel, trackScript } from "../../lib/content.js";

export function getStaticPaths() {
  return content.products.map((product) => ({ params: { slug: product.slug }, props: { product } }));
}

const { product } = Astro.props;
const images = (product.gallery?.length ? product.gallery : product.image ? [product.image] : []).map(assetPath);
const descriptionImages = (product.descriptionImages || []).map(assetPath);
const setupImages = (product.setupImages || []).map(assetPath);
const allLightboxImages = [...images, ...descriptionImages, ...setupImages];
const stock = stockLabel(product);
const stockClass = stock.includes("Out") ? "pill-danger" : stock.includes("Almost") ? "pill-almost-out" : stock.includes("Low") ? "pill-low-stock" : "pill-success";
const bundles = product.softwareBundles || product.supportPacks || [];
const optionsByType = (product.productOptions || []).reduce((groups, option) => {
  if (!groups[option.type]) groups[option.type] = [];
  groups[option.type].push(option);
  return groups;
}, {});
---
<PublicLayout title={product.name} description={product.short_description}>
  <main data-product={product.id}>
    <section class="hero inner">
      <h1>{product.name}</h1>
      <p>{product.short_description}</p>
    </section>
    <section class="section inner product-detail">
      <style>
        .product-detail {
          display: grid;
          grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
          gap: 24px;
          align-items: start;
        }
        .main-image {
          width: 100%;
          aspect-ratio: 4 / 3;
          object-fit: contain;
          background: var(--surface);
          border: 1px solid var(--line);
          border-radius: 8px;
          cursor: zoom-in;
        }
        .thumbs {
          display: flex;
          gap: 8px;
          margin-top: 10px;
          overflow-x: auto;
        }
        .thumbs button {
          width: 72px;
          height: 58px;
          padding: 0;
          border: 1px solid var(--line);
          border-radius: 6px;
          background: var(--surface);
          cursor: pointer;
        }
        .thumbs button.active,
        .thumbs button[aria-current="true"] {
          border-color: var(--accent);
          box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 22%, transparent);
        }
        .thumbs img {
          width: 100%;
          height: 100%;
          object-fit: contain;
          border-radius: 5px;
        }
        .product-options {
          display: grid;
          gap: 10px;
          margin: 14px 0;
        }
        .product-option-field {
          display: grid;
          gap: 4px;
        }
        .product-option-field select,
        .product-option-field input {
          width: 100%;
          min-height: 38px;
        }
        .option-helper {
          margin: 0;
          font-size: 13px;
        }
        .product-lightbox {
          position: fixed;
          inset: 0;
          z-index: 50;
          display: none;
          place-items: center;
          padding: 18px;
          background: rgba(15, 23, 42, 0.86);
        }
        .product-lightbox.open {
          display: grid;
        }
        .product-lightbox img {
          max-width: 92vw;
          max-height: 78vh;
          object-fit: contain;
          transform: scale(var(--zoom, 1));
          transition: transform 120ms ease;
        }
        .lightbox-actions {
          position: fixed;
          left: 18px;
          right: 18px;
          bottom: 18px;
          display: flex;
          flex-wrap: wrap;
          justify-content: center;
          gap: 8px;
        }
        @media (max-width: 860px) {
          .product-detail { grid-template-columns: 1fr; }
        }
      </style>
      <div>
        {images.length ? <img id="mainImage" class="main-image" src={images[0]} alt={product.name} data-lightbox-src={images[0]}> : <div class="placeholder-media">Product image</div>}
        {images.length > 1 && (
          <div class="thumbs">
            {images.map((image, index) => <button class={index === 0 ? "active" : ""} type="button" data-thumb={image} aria-current={index === 0 ? "true" : "false"} aria-label="Show image"><img src={image} alt=""></button>)}
          </div>
        )}
      </div>
      <aside class="card">
        {product.sku && <p><strong>SKU:</strong> {product.sku}</p>}
        {product.version_label && <p><strong>Version:</strong> {product.version_label}</p>}
        {stock && <p><span class={`pill ${stockClass}`} title="Availability shown by the seller">{stock}</span></p>}
        {Object.keys(optionsByType).length > 0 && (
          <div class="product-options">
            <p class="muted option-helper">Selections with linked images update the product photo.</p>
            {Object.entries(optionsByType).map(([type, options]) => (
              <label class="product-option-field">
                <strong>{type}</strong>
                <select data-product-option data-option-type={type}>
                  <option value="">Not selected</option>
                  {options.map((option) => <option value={option.value} data-option-image={option.image ? assetPath(option.image) : ""}>{option.value}</option>)}
                </select>
              </label>
            ))}
          </div>
        )}
        {product.optionNotes && <p class="muted"><strong>Option notes:</strong> {product.optionNotes}</p>}
        <div class="button-row">
          {product.marketplace_url && <a class="button" href={product.marketplace_url} data-track-marketplace={product.id}>{content.settings.defaultMarketplaceLabel}</a>}
          {product.marketplace_qr && <button class="button secondary" type="button" data-qr="marketplace" title="Show marketplace QR code" aria-label="Show marketplace QR code">QR</button>}
          <a class="button secondary" href="#downloads">Software & downloads</a>
        </div>
      </aside>
    </section>
    <section class="section inner">
      <div set:html={product.long_description}></div>
      {descriptionImages.map((image) => <img src={image} alt="" data-lightbox-src={image} style="width: 100%; margin: 18px 0; border-radius: 8px; cursor: zoom-in;">)}
      {setupImages.length > 0 && <h2>Setup screenshots</h2>}
      <div class="grid">{setupImages.map((image) => <img src={image} alt="" data-lightbox-src={image} style="border-radius: 8px; cursor: zoom-in;">)}</div>
    </section>
    <section class="section inner" id="downloads">
      <h2>Software Bundles and downloads</h2>
      {bundles.length > 0 && (
        <div class="grid" style="margin-bottom: 18px;">
          {bundles.map((bundle) => (
            <article class="card">
              <h3>{bundle.name}</h3>
              <p>{bundle.description}</p>
              <div class="button-row">
                {bundle.bundle_url && <a class="button" href={assetPath(bundle.bundle_url)} data-track-software-bundle={bundle.id} title="Download software bundle" aria-label={`Download ${bundle.name}`}>Download software bundle</a>}
              </div>
              <ul>
                {bundle.downloads?.map((download) => <li>{download.name} · {download.type} {download.latest?.version_number ? `· ${download.latest.version_number}` : ""} · <a href={sitePath(`/downloads/${download.slug}/`)} title="View version history" aria-label={`View ${download.name} version history`}>Version history</a></li>)}
              </ul>
              {bundle.externalLinks?.length > 0 && <p class="muted">External app/store links are listed individually and are not included in the ZIP.</p>}
            </article>
          ))}
        </div>
      )}
      <div class="grid">
        {product.downloads?.map((download) => <DownloadCard download={download} />)}
      </div>
    </section>
    {product.related?.length > 0 && (
      <section class="section inner">
        <h2>Related products</h2>
        <div class="grid">{product.related.map((related) => <ProductCard product={related} />)}</div>
      </section>
    )}
  </main>
  {product.marketplace_qr && (
    <div class="qr-popover" id="qrMarketplace">
      <div class="qr-box">
        <h2>Marketplace QR</h2>
        <img src={assetPath(product.marketplace_qr)} alt="Marketplace QR code">
        <button class="button secondary" type="button" data-close-qr>Close</button>
      </div>
    </div>
  )}
  <div class="product-lightbox" id="productLightbox" aria-hidden="true">
    <img alt="">
    <div class="lightbox-actions">
      <button class="button secondary" type="button" data-lightbox-prev>Previous</button>
      <button class="button secondary" type="button" data-lightbox-zoom-in>Zoom in</button>
      <button class="button secondary" type="button" data-lightbox-zoom-out>Zoom out</button>
      <button class="button secondary" type="button" data-lightbox-reset>Reset</button>
      <button class="button" type="button" data-lightbox-next>Next</button>
      <button class="button secondary" type="button" data-lightbox-close>Close</button>
    </div>
  </div>
  <script is:inline set:html={trackScript("product_view", { productId: product.id })} />
  <script is:inline define:vars={{ allLightboxImages }}>
    var lightboxImages = allLightboxImages;
    var lightboxIndex = 0;
    var lightboxZoom = 1;
    var lightbox = document.querySelector("#productLightbox");
    var lightboxImg = lightbox && lightbox.querySelector("img");
    function updateActiveThumb(src) {
      document.querySelectorAll("[data-thumb]").forEach(function(button) {
        var active = button.dataset.thumb === src;
        button.classList.toggle("active", active);
        button.setAttribute("aria-current", active ? "true" : "false");
      });
    }
    function syncOptionsForImage(src) {
      document.querySelectorAll("[data-product-option]").forEach(function(select) {
        var match = "";
        Array.prototype.forEach.call(select.options, function(option) {
          if (!match && option.dataset.optionImage && option.dataset.optionImage === src) match = option.value;
        });
        select.value = match;
      });
    }
    function setMainImage(src, syncOptions) {
      var main = document.querySelector("#mainImage");
      if (main && src) {
        main.src = src;
        main.dataset.lightboxSrc = src;
        updateActiveThumb(src);
        if (syncOptions !== false) syncOptionsForImage(src);
      }
    }
    function openLightbox(src) {
      if (!lightbox || !lightboxImg || !src) return;
      lightboxIndex = Math.max(0, lightboxImages.indexOf(src));
      lightboxZoom = 1;
      lightboxImg.src = src;
      lightboxImg.style.setProperty("--zoom", lightboxZoom);
      lightbox.classList.add("open");
      lightbox.setAttribute("aria-hidden", "false");
    }
    function closeLightbox() {
      if (!lightbox) return;
      lightbox.classList.remove("open");
      lightbox.setAttribute("aria-hidden", "true");
    }
    function moveLightbox(delta) {
      if (!lightboxImages.length || !lightboxImg) return;
      lightboxIndex = (lightboxIndex + delta + lightboxImages.length) % lightboxImages.length;
      lightboxZoom = 1;
      lightboxImg.src = lightboxImages[lightboxIndex];
      lightboxImg.style.setProperty("--zoom", lightboxZoom);
    }
    document.querySelectorAll("[data-thumb]").forEach(function(button) {
      button.addEventListener("click", function() {
        setMainImage(button.dataset.thumb);
      });
    });
    document.querySelectorAll("[data-product-option]").forEach(function(select) {
      select.addEventListener("change", function() {
        var image = select.selectedOptions[0] && select.selectedOptions[0].dataset.optionImage;
        if (image) setMainImage(image);
      });
    });
    var initialMainImage = document.querySelector("#mainImage")?.dataset.lightboxSrc || document.querySelector("#mainImage")?.src || "";
    if (initialMainImage) syncOptionsForImage(initialMainImage);
    document.querySelectorAll("[data-lightbox-src]").forEach(function(item) {
      item.addEventListener("click", function() {
        openLightbox(item.dataset.lightboxSrc || item.src);
      });
    });
    lightbox?.addEventListener("click", function(event) {
      if (event.target === lightbox || event.target.matches("[data-lightbox-close]")) closeLightbox();
      if (event.target.matches("[data-lightbox-prev]")) moveLightbox(-1);
      if (event.target.matches("[data-lightbox-next]")) moveLightbox(1);
      if (event.target.matches("[data-lightbox-zoom-in]")) {
        lightboxZoom = Math.min(3, lightboxZoom + 0.25);
        lightboxImg.style.setProperty("--zoom", lightboxZoom);
      }
      if (event.target.matches("[data-lightbox-zoom-out]")) {
        lightboxZoom = Math.max(0.5, lightboxZoom - 0.25);
        lightboxImg.style.setProperty("--zoom", lightboxZoom);
      }
      if (event.target.matches("[data-lightbox-reset]")) {
        lightboxZoom = 1;
        lightboxImg.style.setProperty("--zoom", lightboxZoom);
      }
    });
    document.addEventListener("keydown", function(event) {
      if (event.key === "Escape") closeLightbox();
    });
    document.querySelectorAll("[data-qr]").forEach(function(button) {
      button.addEventListener("click", function() {
        var modal = document.querySelector("#qrMarketplace");
        if (modal) modal.classList.add("open");
        if (window.KAIRIX_TRACK) window.KAIRIX_TRACK("qr_opened", { productId: Number(button.closest("main")?.dataset.product || "0") });
      });
    });
    document.querySelectorAll("[data-close-qr]").forEach(function(button) {
      button.addEventListener("click", function() {
        button.closest(".qr-popover").classList.remove("open");
      });
    });
  </script>
</PublicLayout>
