# Kairix Express Page Builder deployment example

NODE_ENV=production
ADMIN_PORT=8080
PUBLIC_PREVIEW_PORT=4321
PORT=8080

DATABASE_PATH=/app/data/kairix.sqlite
UPLOADS_DIR=/app/uploads
GENERATED_SITE_DIR=/app/generated-site
BACKUPS_DIR=/app/data/backups
MAX_UPLOAD_MB=25

TRUST_PROXY=true
COOKIE_SECURE=true
ADMIN_BASE_URL=https://your-admin-demo.example.com
PUBLIC_BASE_URL=https://your-admin-demo.example.com
PUBLIC_SITE_BASE_PATH=/preview

# Required in production. Replace both with different long random values.
SESSION_SECRET=replace-with-long-random-secret
ENCRYPTION_SECRET=replace-with-different-long-random-secret

# Demo mode A: single admin URL with built-in preview
# - Expose only the admin service.
# - Public preview is served by the admin at /preview/.
# - Keep PUBLIC_SITE_BASE_PATH=/preview.
# - PUBLIC_BASE_URL should be the admin hostname origin.

# Demo mode B: separate static public preview URL
# - Expose public-preview separately.
# - PUBLIC_SITE_BASE_PATH can be empty/root:
#   PUBLIC_SITE_BASE_PATH=
# - docker-compose.yml uses ${PUBLIC_SITE_BASE_PATH-/preview}, so an intentionally
#   empty value is preserved. Do not change it to ${PUBLIC_SITE_BASE_PATH:-/preview}.
# - PUBLIC_BASE_URL should be the public-preview hostname origin.

# AliExpress Open Platform endpoints and credentials are configured in Settings.
# Leave endpoint values empty until you have confirmed the official endpoints for your app.
ALIEXPRESS_AUTH_URL=
ALIEXPRESS_TOKEN_URL=
ALIEXPRESS_API_URL=

# Future Cloudflare Pages Direct Upload placeholders
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PROJECT_NAME=
CLOUDFLARE_API_TOKEN=

# Future Cloudflare R2 placeholders
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
