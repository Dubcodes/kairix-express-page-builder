NODE_ENV=development
PORT=8080
PUBLIC_PREVIEW_PORT=4321
DATABASE_PATH=./data/kairix.sqlite
UPLOADS_DIR=./uploads
GENERATED_SITE_DIR=./generated-site
PUBLIC_BASE_URL=http://localhost:4321
PUBLIC_SITE_BASE_PATH=/preview
ADMIN_BASE_URL=http://localhost:8080
TRUST_PROXY=false
COOKIE_SECURE=false
SESSION_SECRET=change-this-long-random-secret
MAX_UPLOAD_MB=25

# Future Cloudflare Pages Direct Upload placeholders
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PROJECT_NAME=
CLOUDFLARE_API_TOKEN=

# Future Cloudflare R2 placeholders
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
