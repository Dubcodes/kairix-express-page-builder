# Kairix Express Page Builder deployment example

NODE_ENV=production
ADMIN_BIND_IP=127.0.0.1
ADMIN_PORT=8080
PREVIEW_BIND_IP=127.0.0.1
PUBLIC_PREVIEW_PORT=4321
PORT=8080

DATABASE_PATH=/app/data/kairix.sqlite
UPLOADS_DIR=/app/uploads
GENERATED_SITE_DIR=/app/generated-site/current
PUBLIC_BUILD_TEMP_DIR=/app/generated-site/.publish-staging
BACKUPS_DIR=/app/data/backups
MAX_UPLOAD_MB=25
ENABLE_SAMPLE_DATA_TOOLS=false
PUBLISH_MAX_FILES=20000
PUBLISH_MAX_TOTAL_MB=500
PUBLISH_MAX_FILE_MB=25

# Initial Portainer LAN test defaults. Replace the URL host with the Linux
# server's LAN address and set ADMIN_BIND_IP to that address in Portainer.
TRUST_PROXY=false
COOKIE_SECURE=false
ADMIN_BASE_URL=http://your-linux-server-lan-address:8080
PUBLIC_BASE_URL=http://your-linux-server-lan-address:8080
PUBLIC_SITE_BASE_PATH=/preview
ADMIN_HOSTNAME=
PUBLIC_HOSTNAME=

# Required in production. Replace both with different long random values.
SESSION_SECRET=replace-with-long-random-secret
ENCRYPTION_SECRET=replace-with-different-long-random-secret

# Demo mode A: single admin URL with built-in preview
# - Expose only the admin service.
# - Public preview is served by the admin at /preview/.
# - Keep PUBLIC_SITE_BASE_PATH=/preview.
# - PUBLIC_BASE_URL should be the admin hostname origin.

# Binding policy:
# - ADMIN_BIND_IP defaults to loopback. Set it to the server's LAN IP to make
#   the Page Manager reachable from trusted LAN clients. Do not port-forward it.
# - PREVIEW_BIND_IP defaults to loopback. Keep it there unless a LAN-only
#   standalone preview is specifically required.
# - PORT is the fixed internal application port; normally leave it at 8080.

# The optional public-preview container is bound to localhost for operator testing.
# Do not route it as the production public site.

# AliExpress Open Platform endpoints and credentials are configured in Settings.
# Leave endpoint values empty until you have confirmed the official endpoints for your app.
ALIEXPRESS_AUTH_URL=
ALIEXPRESS_TOKEN_URL=
ALIEXPRESS_API_URL=

# Publishing mode. Keep local until the Cloudflare project and token are ready.
DEPLOY_PROVIDER=local

# Required only when DEPLOY_PROVIDER=cloudflare-pages.
# Also set PUBLIC_BASE_URL to the final HTTPS Pages/custom-domain origin,
# set PUBLIC_SITE_BASE_PATH= (empty), and keep PUBLIC_HOSTNAME= empty.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=
CLOUDFLARE_PAGES_BRANCH=main
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_DEPLOY_TIMEOUT_MS=600000
CLOUDFLARE_PREFLIGHT_TIMEOUT_MS=15000
